<html lang="fr">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Partenariat - Académie Nexar</title>

<link rel="stylesheet" href="partenariat.css">

</head>


<body>


<div class="background"></div>




<!-- NAVBAR -->

<nav>


<div class="logo-area">

<img src="logo.png">

<span>
Académie Nexar
</span>

</div>




<div class="menu">

<a href="index.html">
Accueil
</a>


<a href="adhesion.html">
Adhésion
</a>


